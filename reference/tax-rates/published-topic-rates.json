            {
              "heading": "Main rates and annual exempt amounts",
              "columns": ["Taxpayer or gain", "Amount or rate", "Important point"],
              "rows": [
                ["Individuals — gains within unused basic-rate band", "18%", "The balance above that band is normally charged at 24%."],
                ["Individuals — gains above basic-rate band", "24%", "Taxable income is considered before taxable gains."],
                ["Trustees and personal representatives", "24%", "Subject to the rules for the particular trust or estate."],
                ["Business Asset Disposal Relief or Investors’ Relief", "18%", "Eligibility and lifetime limits apply."],
                ["Annual exempt amount — individuals and personal representatives", "£3,000", "Deducted from gains, subject to eligibility."],
                ["Annual exempt amount — most trustees", "£1,500", "Special sharing rules can apply to related trusts."]
              ]
            }
          ],
          "sourceIds": ["cgt-rates", "budget-2025-annex"]
        },
